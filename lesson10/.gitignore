# Go 相关构建/临时文件（标准 Go 模板精简版）
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.prof
.gocache/
go.work
vendor/

# IDE / 编辑器配置
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# 环境变量 / 敏感文件（最重要！）
.env
.env.local
.env.*
!.env.example          # 如果你有示例模板，可以保留
*.secret
*.key

# 前端 Next.js / Node 相关
node_modules/
my-forum-app/node_modules/
.next/
my-forum-app/.next/
my-forum-app/.swc/
my-forum-app/out/
my-forum-app/build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 静态上传目录（用户文件）
static/uploads/
uploads/

# 压缩包 / 临时打包
*.zip
*.tar.gz
my-forum-app.zip

# 系统临时文件
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# Docker / 构建缓存（可选，根据需要）
docker-compose.override.yml
*.dockerignore

# 其他项目特定（如果有临时生成）
migrations/*.sql.bak   # 如果你有备份迁移文件
